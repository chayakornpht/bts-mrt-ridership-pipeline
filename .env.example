# =============================================
# BTS/MRT Ridership Pipeline - Environment Variables
# =============================================
# Copy this file: cp .env.example .env
# Then fill in your actual values

# Google Maps API Key (get from https://console.cloud.google.com)
# Free $200/month credit - enable Distance Matrix API
GOOGLE_MAPS_API_KEY=your_api_key_here

# LINE Notify Token (optional - for alerting)
# Get from https://notify-bot.line.me/my/
LINE_NOTIFY_TOKEN=your_line_token_here

# Warehouse DB (no need to change - matches docker-compose.yml)
WAREHOUSE_HOST=postgres-warehouse
WAREHOUSE_PORT=5432
WAREHOUSE_DB=bts_mrt
WAREHOUSE_USER=warehouse
WAREHOUSE_PASSWORD=warehouse123
